{
	"servers": {
		"supabase": {
			"type": "http",
			"url": "https://mcp.supabase.com/mcp?project_ref=tbqsazriorqzexjwhekw"
      		}
		},
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
				"ghcr.io/github/github-mcp-server:1.0.0"
			]
		}
	},
	"inputs": [
		{
			"id": "token",
			"type": "promptString",
			"description": "GitHub Personal Access Token",
			"password": true
		}
	]
}